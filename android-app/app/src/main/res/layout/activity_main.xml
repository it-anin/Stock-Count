<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e">

    <!-- WebView fills full screen -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Progress bar at top -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:max="100"
        android:progressTint="#4a90d9"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Floating action buttons: reload + settings -->
    <LinearLayout
        android:id="@+id/fabContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:alpha="0.45"
        android:padding="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="20dp"
        android:layout_marginEnd="8dp">

        <Button
            android:id="@+id/fabReload"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="↺"
            android:textSize="18sp"
            android:textColor="#ffffff"
            android:backgroundTint="#4a90d9"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/fabSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="⚙"
            android:textSize="16sp"
            android:textColor="#ffffff"
            android:backgroundTint="#555577"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp" />

    </LinearLayout>

    <!-- Error overlay -->
    <LinearLayout
        android:id="@+id/errorView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:text="⚠️"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="48sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvErrorMsg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#ffffff"
            android:textSize="15sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="24dp"
            android:text="ไม่สามารถเชื่อมต่อได้" />

        <Button
            android:id="@+id/btnRetry"
            android:layout_width="160dp"
            android:layout_height="48dp"
            android:text="ลองใหม่"
            android:backgroundTint="#4a90d9"
            android:textColor="#ffffff"
            android:textSize="15sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
