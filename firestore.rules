// Firestore Security Rules — เก็บไว้ track ใน git เท่านั้น
// deploy จริงทำผ่าน Firebase Console → Firestore Database → Rules → Publish (ไม่มี Firebase CLI/auto-deploy ผูกไว้)
// แก้ไฟล์นี้แล้วอย่าลืม copy ไป publish ใน Console ด้วย — ไม่งั้นจะไม่ตรงกับของจริง
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // {document=**} ครอบ subcollection ด้วย — จำเป็นสำหรับ stock_sessions/{branch}/items/{sku} (schema v2)
    // wildcard แบบ {document} เดิมเป็น single-segment จึงไม่ครอบ subcollection และ items จะถูกปฏิเสธทั้งหมด
    // สิทธิ์ยังเท่าเดิม (เปิด read/write) — การ tighten rules เป็นงาน security แยกต่างหาก
    match /stock_sessions/{document=**} {
      allow read, write: if true;
    }
    match /stock_audit_log/{document} {
      allow read, write: if true;
    }
    match /stock_countreport/{document} {
      allow read, write: if true;
    }
    match /stock_login_log/{document} {
      allow read, write: if true;
    }
  }
}
